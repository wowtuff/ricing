#!/bin/bash
set -euo pipefail

echo "================================================"
echo " Hyprland Preview Container"
echo "================================================"

PREVIEW_DRM="${PREVIEW_DRM:-/dev/dri/card0}"

mkdir -p /dev/dri /run/dbus /run/user/1000 /home/hypruser/.cache/hyprland
chown hypruser:hypruser /run/user/1000
chown -R hypruser:hypruser /home/hypruser/.cache
chmod 700 /run/user/1000

# Make Hyprland happy if it probes both card0 and card1.
# We only expose one real DRM device, so mirror it as card1 too.
if [ -e "$PREVIEW_DRM" ] && [ ! -e /dev/dri/card1 ]; then
    ln -sf "$PREVIEW_DRM" /dev/dri/card1
fi

# machine-id and dbus
[ -s /etc/machine-id ] || dbus-uuidgen > /etc/machine-id
rm -f /run/dbus/pid
(dbus-daemon --system --fork 2>/dev/null || true)
su - hypruser -c "dbus-launch --sh-syntax > /tmp/dbus-env" 2>/dev/null || true

echo "      available DRM nodes:"
ls -l /dev/dri || true
echo "      selected preview DRM: $PREVIEW_DRM"

# seatd
echo "[1/4] Starting seatd..."
SEATD_VTBOUND=0 seatd -l debug &
SEATD_PID=$!
sleep 1
chmod 777 /run/seatd.sock
if ! kill -0 "$SEATD_PID" 2>/dev/null; then
    echo "ERROR: seatd failed to start"
    exit 1
fi
echo "      seatd running (pid $SEATD_PID)"

# Hyprland
echo "[2/4] Starting Hyprland..."
su - hypruser -c "
    source /tmp/dbus-env 2>/dev/null || true
    export XDG_RUNTIME_DIR=/run/user/1000
    export XDG_SESSION_TYPE=wayland
    export XDG_CURRENT_DESKTOP=Hyprland
    export AQ_DRM_DEVICES=$PREVIEW_DRM
    export AQ_TRACE=1
    export WLR_RENDERER=pixman
    export WLR_NO_HARDWARE_CURSORS=1
    export LIBSEAT_BACKEND=seatd
    export HYPRLAND_NO_SD_NOTIFY=1
    export HYPRLAND_LOG_WLR=1
    exec Hyprland
" &
HYPRLAND_PID=$!

SOCKET=""
for i in $(seq 1 20); do
    if ! kill -0 "$HYPRLAND_PID" 2>/dev/null; then
        echo "ERROR: Hyprland exited before becoming ready"
        wait "$HYPRLAND_PID" || true
        exit 1
    fi

    SOCKET=$(find /run/user/1000/hypr -mindepth 1 -maxdepth 1 -type d 2>/dev/null | head -1 | xargs -r basename)
    if [ -n "$SOCKET" ] && [ -S "/run/user/1000/hypr/$SOCKET/.socket.sock" ]; then
        echo "      Socket ready: $SOCKET"
        break
    fi
    sleep 1
done

if [ -z "$SOCKET" ]; then
    echo "ERROR: Hyprland socket never appeared"
    exit 1
fi

WAYLAND_DISPLAY=$(find /run/user/1000 -maxdepth 1 -type s -name 'wayland-*' 2>/dev/null | head -1 | xargs -r basename)
if [ -z "$WAYLAND_DISPLAY" ]; then
    echo "ERROR: no wayland display socket found"
    exit 1
fi

export HYPRLAND_INSTANCE_SIGNATURE="$SOCKET"
echo "      Wayland display: $WAYLAND_DISPLAY"

echo "[3/4] Creating virtual display..."
su - hypruser -c "
    source /tmp/dbus-env 2>/dev/null || true
    export XDG_RUNTIME_DIR=/run/user/1000
    export WAYLAND_DISPLAY=$WAYLAND_DISPLAY
    export HYPRLAND_INSTANCE_SIGNATURE=$SOCKET
    hyprctl output create headless
" && echo "      Virtual output created" || echo "      Warning: output may already exist"

sleep 1

echo "[4/4] Starting wayvnc on :5070..."
su - hypruser -c "
    source /tmp/dbus-env 2>/dev/null || true
    export XDG_RUNTIME_DIR=/run/user/1000
    export WAYLAND_DISPLAY=$WAYLAND_DISPLAY
    exec wayvnc 0.0.0.0 5070 -o HEADLESS-1
" &
WAYVNC_PID=$!
sleep 1

if ! kill -0 "$WAYVNC_PID" 2>/dev/null; then
    echo "ERROR: wayvnc failed to start"
    exit 1
fi

echo "      Starting noVNC on :6090..."
websockify --web=/opt/novnc 6090 localhost:5070 &
NOVNC_PID=$!

echo ""
echo "================================================"
echo " Ready!"
echo " DRM    : $PREVIEW_DRM"
echo " VNC    : localhost:5070"
echo " Browser: http://localhost:6090"
echo "================================================"

cleanup() {
    kill "$NOVNC_PID" "$WAYVNC_PID" "$HYPRLAND_PID" "$SEATD_PID" 2>/dev/null || true
}
trap cleanup EXIT INT TERM

wait "$HYPRLAND_PID"
