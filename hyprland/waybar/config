{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": ["custom/term", "custom/browser", "custom/menu", "hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["network"],
    "custom/term": {
        "format": "TERM",
        "tooltip": "Open terminal: F1, Alt+Enter, or Super+Enter",
        "on-click": "foot"
    },
    "custom/browser": {
        "format": "WEB",
        "tooltip": "Open Firefox: F2, Alt+B, or Super+B",
        "on-click": "firefox --new-window about:blank"
    },
    "custom/menu": {
        "format": "APPS",
        "tooltip": "Open launcher: F3, Alt+Space, or Super+D",
        "on-click": "rofi -show drun"
    },
    "hyprland/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "1": "一",
            "2": "二",
            "3": "三",
            "4": "四",
            "5": "五",
            "6": "六",
            "7": "七",
            "8": "八",
            "9": "九",
            "10": "十",
            "urgent": "",
            "focused": ""
        },
        "persistent-workspaces": {
            "*": 5
        }
    },
    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%Y-%m-%d}",
        "tooltip-format": "{:%Y-%m-%d | %H:%M}"
    },
    "network": {
        "format-wifi": "󰤨 {signalStrength}%",
        "format-ethernet": "󰈀",
        "tooltip-format": "{ifname} - {ipaddr}",
        "format-linked": "󰈀 {ifname}",
        "format-disconnected": "󰤭",
        "format-alt": "{ifname}: {ipaddr}",
        "interval": 5
    }
}
